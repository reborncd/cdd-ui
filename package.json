{
  "name": "cdd-ui",
  "version": "0.1.4",
  "description": "",
  "main": "index.js",
  "keywords": [
    "vue component",
    "vue3 component",
    "vite",
    "cdd-ui"
  ],
  "files": [
    "dist",
    "README.md",
    "package.json"
  ],
  "scripts": {
    "dev": "vite --open --force",
    "doc:build": "vite build",
    "build:libs:json": "node scripts/component-json",
    "build:libs:all": "vite build --config vite.config.build.ts && node scripts/generate-file && node scripts/generate-themes && vite build --config vite.config.build.css.ts && npm run build:locale && npm run generate:pck",
    "generate:css": "vite build --config vite.config.build.css.ts",
    "build:locale": "vite build --config vite.config.build.locale.ts",
    "build:libs:components": "vite build --config vite.config.build.disperse.ts && node scripts/generate-themes && vite build --config vite.config.build.css.ts && npm run build:locale && npm run generate:pck",
    "generate:pck": "node scripts/generate-package.js",
    "tem": "node scripts/template",
    "generate:files": "node scripts/generate-ui.js"
  },
  "repository": {
    "type": "git",
    "url": ""
  },
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@ant-design/icons-vue": "^7.0.1",
    "@popperjs/core": "^2.10.2",
    "@vue/shared": "^3.5.1",
    "@vueuse/core": "^7.1.2",
    "ant-design-vue": "^4.2.3",
    "dayjs": "^1.11.9",
    "hls.js": "^1.1.5",
    "js-base64": "^3.7.7",
    "line-reader": "^0.4.0",
    "lodash": "^4.17.21",
    "lodash-es": "^4.17.21",
    "lodash-unified": "^1.0.2",
    "moment": "^2.30.1",
    "sass": "^1.49.0",
    "vue": "^3.2.30",
    "vue-clipboard3": "^2.0.0",
    "vue-draggable-next": "^2.2.1",
    "vue-router": "^4.0.11",
    "vuedraggable": "^2.24.3",
    "vxe-table": "4.7.80"
  },
  "devDependencies": {
    "@rollup/plugin-commonjs": "^21.0.1",
    "@rollup/plugin-node-resolve": "^13.0.6",
    "@types/lodash": "^4.14.195",
    "@types/lodash-es": "^4.17.8",
    "@types/node": "^17.0.10",
    "@typescript-eslint/eslint-plugin": "^4.20.0",
    "@typescript-eslint/parser": "^4.20.0",
    "@vitejs/plugin-legacy": "^1.4.0",
    "@vitejs/plugin-vue": "^1.2.2",
    "@vitejs/plugin-vue-jsx": "^1.2.0",
    "@vue/eslint-config-typescript": "^7.0.0",
    "async-validator": "^4.0.7",
    "autoprefixer": "^10.3.4",
    "fast-glob": "^3.3.2",
    "fs-extra": "^11.2.0",
    "linebyline": "^1.3.0",
    "typescript": "^4.1.5",
    "vite": "^2.3.4",
    "vite-plugin-md": "^0.11.0",
    "vite-plugin-vuedoc": "^3.1.3",
    "vue-jest": "^5.0.0-alpha.7"
  },
  "eslintConfig": {
    "root": true,
    "env": {
      "node": true
    },
    "extends": [
      "plugin:vue/vue3-essential",
      "eslint:recommended",
      "@vue/typescript/recommended",
      "@vue/prettier",
      "@vue/prettier/@typescript-eslint"
    ],
    "parserOptions": {
      "ecmaVersion": 2020
    },
    "rules": {
      "vue/no-unused-components": "off",
      "no-debugger": "off"
    }
  },
  "lint-staged": {
    "*.md": "prettier --write",
    "*.{ts,tsx,js,vue,scss}": "prettier --write"
  },
  "packageManager": "yarn@1.22.22+sha512.a6b2f7906b721bba3d67d4aff083df04dad64c399707841b7acf00f6b133b7ac24255f2652fa22ae3534329dc6180534e98d17432037ff6fd140556e2bb3137e"
}
